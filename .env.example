# ImiRezervimi.al Environment Variables
# Copy this file to .env.local and fill in your actual values

# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
# Get these from: https://supabase.com/dashboard/project/[project-id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ==============================================
# INSTAGRAM API (Meta Developers)
# ==============================================
# Get these from: https://developers.facebook.com/apps/
INSTAGRAM_CLIENT_ID=your_instagram_app_id
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/auth/instagram/callback

# ==============================================
# GOOGLE OAUTH (Optional - for Google login)
# ==============================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==============================================
# TWILIO WHATSAPP API
# ==============================================
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# PRODUCTION: Use your approved WhatsApp Business number
TWILIO_WHATSAPP_NUMBER=+1234567890

# SANDBOX (development only): Use Twilio sandbox number
# TWILIO_WHATSAPP_NUMBER=+14155238886

# Optional: Messaging Service SID (for advanced routing)
# TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid

# WhatsApp message template options
# Use simple English template (more likely to be approved by WhatsApp)
WHATSAPP_USE_SIMPLE_TEMPLATE=false

# WhatsApp Message Templates (REQUIRED for production)
# Set to true to use approved message templates instead of freeform messages
WHATSAPP_USE_MESSAGE_TEMPLATE=true
# Template SID from Twilio Console (Content Templates)
WHATSAPP_TEMPLATE_SID=your_whatsapp_template_sid_here

# SMS number (optional, not used for WhatsApp-only setup)
# TWILIO_PHONE_NUMBER=your_twilio_phone_number_for_sms

# Test phone number for development (Albanian format)
TWILIO_TEST_PHONE_NUMBER=+355691234567

# ==============================================
# NEXTAUTH CONFIGURATION
# ==============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key_here

# ==============================================
# APPLICATION SETTINGS
# ==============================================
# Environment: development, staging, production
NODE_ENV=development

# Albanian timezone
TZ=Europe/Tirane

# Default language
DEFAULT_LOCALE=sq

# ==============================================
# OPTIONAL: PRODUCTION ONLY
# ==============================================
# Sentry error tracking (production)
# SENTRY_DSN=your_sentry_dsn_here

# Analytics (production)
# GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# ==============================================
# DATABASE (If using direct connection)
# ==============================================
# Usually not needed with Supabase, but kept for reference
# DATABASE_URL=postgresql://username:password@host:port/database

# ==============================================
# SECURITY KEYS
# ==============================================
# JWT secret for custom auth (if not using Supabase auth)
# JWT_SECRET=your_jwt_secret_here

# Encryption key for sensitive data
# ENCRYPTION_KEY=your_32_character_encryption_key

# ==============================================
# RATE LIMITING
# ==============================================
# Requests per minute for booking API
RATE_LIMIT_RPM=60

# Max pending requests per customer
MAX_PENDING_REQUESTS=2

# ==============================================
# BUSINESS LOGIC
# ==============================================
# Maximum days in advance for booking
MAX_BOOKING_DAYS=10

# Minimum minutes before appointment for cancellation
MIN_CANCELLATION_MINUTES=30

# Default appointment duration (minutes)
DEFAULT_APPOINTMENT_DURATION=30